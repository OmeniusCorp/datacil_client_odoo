<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="datacil_client_odoo.datacil_dashboard" owl="1">
        <div class="h-100 overflow-auto">
            <div class="container py-3">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="mb-0">Datacil Dashboard</h2>
                    <button class="btn btn-primary" t-on-click="onRefresh" t-att-disabled="state.loading">
                        <i class="fa fa-refresh me-1" t-att-class="{'fa-spin': state.loading}"/>
                        Actualizar
                    </button>
                </div>

                <!-- Loading -->
                <t t-if="state.loading">
                    <div class="text-center py-5">
                        <i class="fa fa-spinner fa-spin fa-3x text-primary"/>
                        <p class="mt-3 text-muted">Cargando datos...</p>
                    </div>
                </t>

                <!-- Error -->
                <t t-elif="state.error">
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="fa fa-exclamation-triangle me-2 fa-lg"/>
                        <span t-esc="state.error"/>
                    </div>
                </t>

                <!-- Dashboard Content -->
                <t t-else="">
                    <!-- KPI Cards -->
                    <div class="row mb-4">
                        <div class="col-md-4 mb-3">
                            <div class="card border-primary h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted mb-1">Balance de Créditos</div>
                                    <h1 class="text-primary mb-0" t-esc="state.credits?.balance || 0"/>
                                    <small class="text-muted" t-esc="state.credits?.currency || 'credits'"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card border-warning h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted mb-1">Total Consumido</div>
                                    <h1 class="text-warning mb-0" t-esc="totalSpent"/>
                                    <small class="text-muted">créditos usados</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card border-info h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted mb-1">Consultas Realizadas</div>
                                    <h1 class="text-info mb-0" t-esc="state.history.length"/>
                                    <small class="text-muted">transacciones</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Costs Table -->
                        <div class="col-md-5 mb-4">
                            <div class="card h-100">
                                <div class="card-header bg-white">
                                    <h5 class="mb-0"><i class="fa fa-tags me-2"/>Costos por Servicio</h5>
                                </div>
                                <div class="card-body p-0">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Servicio</th>
                                                <th>Descripción</th>
                                                <th class="text-end">Costo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.costs" t-as="cost" t-key="cost.serviceKey">
                                                <tr>
                                                    <td>
                                                        <span class="badge bg-secondary" style="color: white" t-esc="cost.serviceKey"/>
                                                    </td>
                                                    <td class="text-muted small" t-esc="cost.description"/>
                                                    <td class="text-end">
                                                        <span t-if="cost.cost === 0" class="badge bg-success">Gratis</span>
                                                        <span t-else="" class="fw-bold" t-esc="cost.cost + ' cr'"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Usage Breakdown -->
                        <div class="col-md-7 mb-4">
                            <div class="card mb-4">
                                <div class="card-header bg-white">
                                    <h5 class="mb-0"><i class="fa fa-pie-chart me-2"/>Consumo por Servicio</h5>
                                </div>
                                <div class="card-body p-0">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Servicio</th>
                                                <th class="text-end">Consultas</th>
                                                <th class="text-end">Créditos</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="serviceBreakdown" t-as="item" t-key="item.service">
                                                <tr>
                                                    <td>
                                                        <span class="badge bg-primary" style="color: white" t-esc="item.service"/>
                                                    </td>
                                                    <td class="text-end" t-esc="item.count"/>
                                                    <td class="text-end fw-bold" t-esc="item.total"/>
                                                </tr>
                                            </t>
                                            <t t-if="serviceBreakdown.length === 0">
                                                <tr><td colspan="3" class="text-center text-muted py-3">Sin datos</td></tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Transaction History -->
                            <div class="card">
                                <div class="card-header bg-white">
                                    <h5 class="mb-0"><i class="fa fa-history me-2"/>Historial de Transacciones</h5>
                                </div>
                                <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light" style="position: sticky; top: 0;">
                                            <tr>
                                                <th>Fecha</th>
                                                <th>Servicio</th>
                                                <th>Consulta</th>
                                                <th class="text-end">Créditos</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.history" t-as="tx" t-key="tx.$id">
                                                <tr>
                                                    <td class="text-muted small text-nowrap" t-esc="tx.date"/>
                                                    <td>
                                                        <span class="badge bg-primary" style="color: white" t-esc="tx.service_key"/>
                                                    </td>
                                                    <td>
                                                        <code t-esc="tx.query_param"/>
                                                    </td>
                                                    <td class="text-end text-danger fw-bold" t-esc="tx.amount"/>
                                                </tr>
                                            </t>
                                            <t t-if="state.history.length === 0">
                                                <tr><td colspan="4" class="text-center text-muted py-3">Sin transacciones</td></tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
