<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_form_inherit_validate_id" model="ir.ui.view">
        <field name="name">res.partner.form.validate.id</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="l10n_latam_base.view_partner_latam_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <label for="button" class="btn btn-sm btn-primary"/>
                <field name="button" nolabel="1" style="display: none;"/>
            </xpath>
        </field>
    </record>
</odoo>
